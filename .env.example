# Kenko AI Healthcare Platform - Environment Configuration
# Copy to .env and fill in your values

# App
SECRET_KEY=change-me-use-openssl-rand-hex-32
DEBUG=true
# Comma-separated. Include your Vercel URL(s), e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# Used for Stripe redirects and links in emails
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://kenko:kenko@postgres:5432/kenko
DATABASE_URL_SYNC=postgresql://kenko:kenko@postgres:5432/kenko

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# AI - Set your API keys here (DO NOT commit .env to git)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GOOGLE_MAPS_API_KEY=
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Subscription test accounts (comma-separated, no payment required)
TEST_ACCOUNT_EMAILS=toms90305@gmail.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@kenko-ai.jp

# Frontend (local dev — on Vercel set NEXT_PUBLIC_API_URL in project env vars)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
